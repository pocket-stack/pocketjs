{
  "$schema": "https://pocketjs.dev/schema/pocket-2.json",
  "pocket": 2,
  "id": "dev.pocket-stack.note",
  "name": "pocket-note",
  "title": "Pocket Note",
  "version": "0.1.0",
  "engine": {
    "capabilities": {
      "requires": [
        "text.glyphs.baked",
        "input.buttons"
      ],
      "enhances": [
        "input.text",
        "input.pointer",
        "input.ime",
        "host.clipboard",
        "display.viewport.live",
        "text.glyphs.runtime"
      ]
    }
  },
  "app": {
    "entry": "demos/note/main.tsx",
    "output": "note-main",
    "framework": "solid",
    "viewport": {
      "logical": [420, 560],
      "presentation": "native"
    }
  }
}
