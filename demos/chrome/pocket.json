{
  "$schema": "https://pocketjs.dev/schema/pocket-2.json",
  "pocket": 2,
  "id": "dev.pocket-stack.chrome",
  "name": "pocketjs-chrome",
  "title": "PocketJS: Chrome",
  "version": "0.6.0",
  "engine": {
    "capabilities": {
      "requires": [
        "text.glyphs.baked",
        "input.buttons"
      ]
    }
  },
  "app": {
    "entry": "demos/chrome/main.tsx",
    "output": "chrome-main",
    "framework": "solid",
    "viewport": {
      "logical": [
        480,
        272
      ],
      "presentation": "integer-fit"
    }
  }
}
