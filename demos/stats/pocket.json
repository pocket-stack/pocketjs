{
  "$schema": "https://pocketjs.dev/schema/pocket-2.json",
  "pocket": 2,
  "id": "dev.pocket-stack.stats",
  "name": "pocketjs-stats",
  "title": "PocketJS: Mission Control",
  "version": "0.6.0",
  "engine": {
    "capabilities": {
      "requires": [
        "text.glyphs.baked",
        "input.buttons"
      ]
    }
  },
  "app": {
    "entry": "demos/stats/main.tsx",
    "output": "stats-main",
    "framework": "solid",
    "viewport": {
      "fixed": {
        "logical": [
          480,
          272
        ],
        "presentation": "integer-fit"
      }
    }
  }
}
