{
  "$schema": "https://pocketjs.dev/schema/pocket-2.json",
  "pocket": 2,
  "id": "dev.pocket-stack.cafe",
  "name": "pocketjs-cafe",
  "title": "PocketJS: Caf\u00e9",
  "version": "0.6.0",
  "engine": {
    "capabilities": {
      "requires": [
        "text.glyphs.baked",
        "input.buttons"
      ]
    }
  },
  "app": {
    "entry": "demos/cafe/main.tsx",
    "output": "cafe-main",
    "framework": "solid",
    "viewport": {
      "logical": [
        480,
        272
      ],
      "presentation": "integer-fit"
    }
  }
}
