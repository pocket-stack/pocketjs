{
  "$schema": "https://pocketjs.dev/schema/pocket-2.json",
  "pocket": 2,
  "id": "dev.pocket-stack.motions",
  "name": "pocketjs-motions",
  "title": "PocketJS: Motion Lab (yui540 studies on baked keyframe timelines)",
  "version": "0.6.0",
  "engine": {
    "capabilities": {
      "requires": [
        "text.glyphs.baked",
        "input.buttons"
      ]
    }
  },
  "app": {
    "entry": "demos/motions/main.tsx",
    "output": "motions-main",
    "framework": "solid",
    "viewport": {
      "logical": [
        480,
        272
      ],
      "presentation": "integer-fit"
    }
  }
}
