# dependency and platform noise
node_modules/
target/
.DS_Store

# pass-1 transform cache (content-hash keyed; safe to delete any time)
.cache/
# per-app build output of scripts/build.ts (dist/ is ignored repo-wide too)
dist/
# resolved per-target manifests/type environments
.pocket/
# regenerated by every `bun scripts/build.ts <app>` run
src/styles.generated.ts
# regenerated by `bun scripts/launcher.ts covers` (deterministic sim renders;
# registry.generated.ts is COMMITTED — scan output, small and reviewable, so
# single-app launcher builds and the psplink picker work on a fresh checkout;
# missing covers bake as placeholders until the covers step runs)
demos/launcher/covers/
# built wasm backend (regenerated by `bun scripts/wasm.ts`)
host-web/pocketjs.wasm
# generated per-demo XMB metadata (scripts/psp.ts, from demos/<app>/psp/Psp.toml)
native/Psp.toml
# Obsolete checkout-local SDK location; bootstrap uses the shared cache.
mipsel-sony-psp/
# golden-mismatch dumps written by test/golden.ts
test/goldens/*.actual.png
# golden-mismatch dumps written by test/e2e-ppsspp.ts
test/goldens-psp/*.actual.png
