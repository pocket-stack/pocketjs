{
  "name": "@pocketjs/aot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Ahead-of-time partial-evaluation pipeline: author tile-based RPGs in TypeScript/JSX, ship GBA-native tiles, sprites, palettes and bytecode. A first-class PocketJS architecture alongside @pocketjs/framework.",
  "exports": {
    ".": "./dsl/index.ts",
    "./jsx-runtime": "./dsl/jsx-runtime.ts",
    "./compiler": "./compiler/index.ts",
    "./spec": "./spec/pjgb.ts"
  },
  "bin": {
    "pocket-aot": "./compiler/cli.ts"
  },
  "scripts": {
    "build": "bun compiler/cli.ts build demo/game.tsx --out dist/pocket-town.gba",
    "play": "bash play.sh",
    "gen": "bun spec/gen-c.ts",
    "handcart": "bun test/handcart.ts",
    "test": "bun test/e2e.ts"
  },
  "devDependencies": {
    "typescript": "^5"
  }
}
