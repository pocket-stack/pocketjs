{
  "name": "psp-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "JSX UI stack for the Sony PSP (and beyond): Solid universal renderer over a no_std Rust core. See DESIGN.md.",
  "scripts": {
    "build": "bun scripts/build.ts",
    "psp": "bun scripts/psp.ts",
    "psp:all": "bun scripts/psp-all.ts",
    "hw": "bun scripts/hw.ts",
    "dev": "bun scripts/dev.ts",
    "wasm": "bun scripts/wasm.ts",
    "serve": "bun host-web/serve.ts",
    "golden": "bun test/golden.ts",
    "e2e": "bun test/e2e-ppsspp.ts",
    "test": "bun scripts/build.ts demos/hero.tsx >/dev/null && bun test/contract.ts && bun test --conditions=browser test/tailwind.test.ts test/renderer.test.ts test/svg-bake.test.ts",
    "test:tailwind": "bun test test/tailwind.test.ts",
    "contract": "bun test/contract.ts",
    "gen": "bun spec/gen-rust.ts"
  },
  "dependencies": {
    "solid-js": "^1.9"
  },
  "devDependencies": {
    "@babel/core": "^7",
    "@babel/preset-typescript": "^7",
    "@types/babel__core": "^7.20.5",
    "@types/bun": "^1.2",
    "@types/opentype.js": "^1.3.10",
    "babel-preset-solid": "^1.9",
    "opentype.js": "^1.3",
    "typescript": "^5"
  }
}
