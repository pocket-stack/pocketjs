{
  "name": "@pocketjs/framework",
  "version": "0.3.0",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pocket-stack/pocketjs.git"
  },
  "homepage": "https://pocketjs.dev",
  "keywords": [
    "pocketjs",
    "psp",
    "solid",
    "vue-vapor",
    "tailwind",
    "jsx",
    "embedded-ui",
    "wasm"
  ],
  "files": [
    "src",
    "compiler",
    "spec",
    "scripts",
    "host-web",
    "assets/fonts",
    "core/src",
    "core/Cargo.toml",
    "wasm/src",
    "wasm/Cargo.toml",
    "native/src",
    "native/targets",
    "native/build.rs",
    "native/Cargo.toml",
    "pocket.config.ts",
    "tsconfig.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": "./src/index.ts",
    "./animation": "./src/animation.ts",
    "./clock": "./src/clock.ts",
    "./config": "./src/config.ts",
    "./components": "./src/components.ts",
    "./devtools": "./src/devtools.ts",
    "./effects": "./src/effects.ts",
    "./lifecycle": "./src/lifecycle.ts",
    "./hot": "./src/hot.ts",
    "./input": "./src/input-api.ts",
    "./prelude": "./src/prelude.ts",
    "./renderer": "./src/renderer.ts",
    "./solid": "./src/index.ts",
    "./solid/components": "./src/components.ts",
    "./solid/lifecycle": "./src/lifecycle.ts",
    "./solid/renderer": "./src/renderer-solid.ts",
    "./vue-vapor": "./src/index-vue-vapor.ts",
    "./vue-vapor/animation": "./src/animation.ts",
    "./vue-vapor/clock": "./src/clock.ts",
    "./vue-vapor/effects": "./src/effects.ts",
    "./vue-vapor/components": "./src/components-vue-vapor.ts",
    "./vue-vapor/input": "./src/input-api.ts",
    "./vue-vapor/lifecycle": "./src/lifecycle-vue-vapor.ts",
    "./vue-vapor/renderer": "./src/renderer-vue-vapor.ts"
  },
  "description": "High-performance JSX UI outside the browser, with native rendering, standard Vue Vapor and Solid support, a Tailwind design system, and 60 FPS animation under an 8 MB memory budget.",
  "scripts": {
    "build": "bun scripts/build.ts",
    "psp": "bun scripts/psp.ts",
    "psp:all": "bun scripts/psp-all.ts",
    "psp:switch": "bun psplink",
    "hw": "bun scripts/hw.ts",
    "dev": "bun scripts/dev.ts",
    "wasm": "bun scripts/wasm.ts",
    "gba:imagegen": "bun imagegen",
    "serve": "bun host-web/serve.ts",
    "golden": "bun test/golden.ts",
    "e2e": "bun test/e2e-ppsspp.ts",
    "test": "bun scripts/build.ts hero >/dev/null && bun test/contract.ts && bun test --conditions=browser test/tailwind.test.ts test/renderer.test.ts test/svg-bake.test.ts test/devtools.test.ts test/hot.test.ts test/clock.test.ts test/tiles.test.ts && bun scripts/build.ts cafe-main >/dev/null && bun test --conditions=browser test/sim.test.ts && bun scripts/build.ts zoomlab-main >/dev/null && bun test --conditions=browser test/deepzoom-sim.test.ts && bun scripts/build.ts rally-main >/dev/null && bun test --conditions=browser playset/test/",
    "tape": "bun scripts/tape.ts",
    "tape:check": "bun scripts/tape.ts replay hero-main test/tapes/hero-main.tape.json --assert test/tapes/hero-main.hashes.json",
    "devtools": "bun scripts/devtools.ts",
    "devtools:psp": "bun scripts/devtools-psp.ts",
    "test:tailwind": "bun test test/tailwind.test.ts",
    "contract": "bun test/contract.ts",
    "gen": "bun spec/gen-rust.ts"
  },
  "dependencies": {
    "@vue/compiler-vapor": "3.6.0-beta.17",
    "solid-js": "^1.9",
    "vue": "3.6.0-beta.17",
    "vue-jsx-vapor": "3.2.17"
  },
  "devDependencies": {
    "@babel/core": "^7",
    "@babel/preset-typescript": "^7",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/state": "^6.7.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@napi-rs/canvas": "^1.0.2",
    "@napi-rs/wasm-runtime": "1.1.5",
    "@tailwindcss/cli": "^4.3.2",
    "@tailwindcss/typography": "^0.5.20",
    "@types/babel__core": "^7.20.5",
    "@types/bun": "^1.2",
    "@types/opentype.js": "^1.3.10",
    "babel-preset-solid": "^1.9",
    "codemirror": "^6.0.2",
    "marked": "^18.0.5",
    "opentype.js": "^1.3",
    "shiki": "^4.3.1",
    "tailwindcss": "^4.3.2",
    "typescript": "^5"
  },
  "trustedDependencies": [
    "@parcel/watcher"
  ]
}
