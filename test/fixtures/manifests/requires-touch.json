{
  "$schema": "https://pocketjs.dev/schema/pocket-2.json",
  "pocket": 2,
  "id": "dev.pocket-stack.touch-first",
  "name": "pocket-touch-first",
  "title": "Pocket Touch First",
  "version": "0.1.0",
  "engine": {
    "capabilities": {
      "requires": [
        "input.touch"
      ],
      "enhances": [
        "input.buttons"
      ]
    }
  },
  "app": {
    "entry": "app/main.tsx",
    "framework": "solid",
    "viewport": {
      "logical": [480, 272],
      "presentation": "integer-fit"
    }
  }
}
