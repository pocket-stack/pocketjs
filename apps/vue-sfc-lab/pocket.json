{
  "$schema": "https://pocketjs.dev/schema/pocket-2.json",
  "pocket": 2,
  "id": "dev.pocket-stack.vue.sfc.lab",
  "name": "pocketjs-vue-sfc-lab",
  "title": "PocketJS: Vue SFC Feature Lab",
  "version": "0.6.0",
  "engine": {
    "capabilities": {
      "requires": [
        "text.glyphs.baked",
        "input.buttons"
      ]
    }
  },
  "app": {
    "entry": "apps/vue-sfc-lab/main.ts",
    "output": "vue-sfc-lab-main",
    "framework": "vue-vapor",
    "viewport": {
      "fixed": {
        "logical": [
          480,
          272
        ],
        "presentation": "integer-fit"
      }
    }
  }
}
