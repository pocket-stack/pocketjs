{
  "$schema": "https://pocketjs.dev/schema/pocket-2.json",
  "pocket": 2,
  "id": "dev.pocket-stack.ipod-nano",
  "name": "pocketjs-ipod-nano",
  "title": "iPod nano 2 — PocketJS",
  "version": "0.6.0",
  "engine": {
    "capabilities": {
      "requires": [
        "text.glyphs.baked",
        "input.buttons"
      ]
    }
  },
  "app": {
    "entry": "apps/ipod-nano/main.tsx",
    "output": "ipod-nano-main",
    "framework": "solid",
    "viewport": {
      "fixed": {
        "logical": [
          176,
          132
        ],
        "presentation": "native"
      }
    }
  }
}
