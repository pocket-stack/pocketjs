{
  "$schema": "https://pocketjs.dev/schema/pocket-2.json",
  "pocket": 2,
  "id": "dev.pocket-stack.settings",
  "name": "pocketjs-settings",
  "title": "PocketJS: Settings",
  "version": "0.6.0",
  "engine": {
    "capabilities": {
      "requires": [
        "text.glyphs.baked",
        "input.buttons"
      ]
    }
  },
  "app": {
    "entry": "apps/settings/main.tsx",
    "output": "settings-main",
    "framework": "solid",
    "viewport": {
      "fixed": {
        "logical": [
          480,
          272
        ],
        "presentation": "integer-fit"
      }
    }
  }
}
